# ----------------------------------------------------------------------------
# Kernels & Bloom — environment variables
# Copy to `.env.local` and fill in. The site runs on local placeholder data
# when these are absent; adapters in src/lib/integrations switch to the live
# service as soon as the relevant keys are provided.
# ----------------------------------------------------------------------------

# Site
NEXT_PUBLIC_SITE_URL=https://kernelsandbloom.com

# Shopify (headless Storefront API)
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_STORE_DOMAIN=

# Supabase (quiz results, B2B applications, consultations, CMS content)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# CMS dashboard (/admin) — default password is password1234 when unset
CMS_ADMIN_PASSWORD=password1234
CMS_SESSION_SECRET=

# Klaviyo (newsletter, post-purchase, quiz result flows)
KLAVIYO_API_KEY=
NEXT_PUBLIC_KLAVIYO_LIST_ID=

# Mapbox (Africa sourcing map). Without this the static SVG map is used.
NEXT_PUBLIC_MAPBOX_TOKEN=
